# =============================================================================
# Dockerfile for nixl-topo-disc
# Auto-generated paths from CMake - do not edit Dockerfile directly,
# edit Dockerfile.in and re-run cmake to regenerate.
# =============================================================================

# Build stage
FROM ubuntu:22.04 AS builder

# Build dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    autoconf \
    automake \
    libtool \
    git \
    pkg-config \
    python3 \
    python3-pip \
    pybind11-dev \
    && rm -rf /var/lib/apt/lists/*

# Install newer meson (NIXL requires >= 0.64.0)
RUN pip3 install meson>=0.64.0

WORKDIR /build

# Copy source
COPY . /src

# Build with specified install prefix
# Note: Dependencies (UCX, NIXL) are built to /build/deps_install
# We then copy them to the install prefix
RUN cmake -S /src -B /build \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=@CONTAINER_INSTALL_PREFIX@ \
    -DBUILD_DEPS_FROM_SOURCE=ON \
    -DBUILD_CONTROLLER=ON \
    -DBUILD_AGENT=ON \
    && cmake --build /build -j$(nproc)

# Install project binaries
RUN cmake --install /build

# Copy built dependencies to install prefix
# UCX libraries
RUN mkdir -p @CONTAINER_INSTALL_PREFIX@/lib && \
    cp -a /build/deps_install/ucx/lib/*.so* @CONTAINER_INSTALL_PREFIX@/lib/ 2>/dev/null || true && \
    cp -a /build/deps_install/ucx/lib/ucx @CONTAINER_INSTALL_PREFIX@/lib/ 2>/dev/null || true

# NIXL libraries and plugins
RUN mkdir -p @CONTAINER_LIB_PATH@ && \
    mkdir -p @CONTAINER_NIXL_PLUGIN_DIR@ && \
    cp -a /build/deps_install/nixl/lib/x86_64-linux-gnu/*.so* @CONTAINER_LIB_PATH@/ 2>/dev/null || true && \
    cp -a /build/deps_install/nixl/lib/x86_64-linux-gnu/plugins/*.so* @CONTAINER_NIXL_PLUGIN_DIR@/ 2>/dev/null || true

# =============================================================================
# Runtime stage
# =============================================================================
FROM ubuntu:22.04 AS runtime

# Runtime dependencies
RUN apt-get update && apt-get install -y \
    libstdc++6 \
    libibverbs1 \
    librdmacm1 \
    libnuma1 \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Copy installed files from builder
COPY --from=builder @CONTAINER_INSTALL_PREFIX@ @CONTAINER_INSTALL_PREFIX@

# Copy entrypoint
COPY --from=builder /build/docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# =============================================================================
# Environment variables for NIXL/UCX
# Paths are relative to CONTAINER_INSTALL_PREFIX: @CONTAINER_INSTALL_PREFIX@
# =============================================================================
ENV NIXL_TOPO_PREFIX="@CONTAINER_INSTALL_PREFIX@"
ENV LD_LIBRARY_PATH="@CONTAINER_LIB_PATH@:@CONTAINER_UCX_LIB_PATH@"
ENV NIXL_PLUGIN_DIR="@CONTAINER_NIXL_PLUGIN_DIR@"
ENV PATH="@CONTAINER_INSTALL_PREFIX@/bin:${PATH}"

# UCX configuration (optional tuning)
ENV UCX_LOG_LEVEL="warn"

WORKDIR @CONTAINER_INSTALL_PREFIX@

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--help"]
